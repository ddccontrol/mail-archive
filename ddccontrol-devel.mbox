 			"If your graphics card need it, please check all the required
kernel modules are loaded (i2c-dev, and your framebuffer driver).\n"
 		    ), fn, ret);
+	} else if (probe && (ret = ddcci_read_details(&mon)) < 0) {
+		fprintf(stderr, _(
+			"\nUnable to read monitor details from database (ddc_read_details
returned %d).\n"
