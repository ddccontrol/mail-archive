ddccontrol-0.4.2.faster/src/ddccontrol/main.c
--- ddccontrol-0.4.2/src/ddccontrol/main.c	2006-07-27 13:45:08.000000000 -0700
+++ ddccontrol-0.4.2.faster/src/ddccontrol/main.c	2009-01-30
12:45:03.000000000 -0800
@@ -343,6 +343,10 @@
 			"\nDDC/CI at %s is unusable (%d).\n"
 			"If your graphics card need it, please check all the required
kernel modules are loaded (i2c-dev, and your framebuffer driver).\n"
 		    ), fn, ret);
+	} else if (probe && (ret = ddcci_read_details(&mon)) < 0) {
+		fprintf(stderr, _(
+			"\nUnable to read monitor details from database (ddc_read_details
returned %d).\n"
+			), ret);
 	} else {
 		fprintf(stdout, _("\nEDID readings:\n"));
 		fprintf(stdout, _("\tPlug and Play ID: %s [%s]\n"),
