   Initial sample. 226BW will be available in retail on March 2007.

   Monitor has additional MagicBright mode "Dynamic contrast" so it 
needs to be added to options.xml, control "magicbright":

<control id="magicbright" type="list" name="Magic Bright Mode" 
address="0xDC">
   <value id="text" name="Text" />
   <value id="internet" name="Internet" />
   <value id="game" name="Game" />
   <value id="sport" name="Sport" />
   <value id="entertain" name="Entertain" />
   <value id="custom" name="Custom" />
   <value id="dynamic" name="Dynamic Contrast" />
</control>

--------------070702020903090903030304
Content-Type: text/xml;
 name="SAM027D.xml"
Content-Transfer-Encoding: 7bit
Content-Disposition: inline;
 filename="SAM027D.xml"

<?xml version="1.0"?>
<!-- (type(LCD)vcp(04 05 08 10 12 16 18 1A 60(1 3) 87 B0(1 2) B6 C6
C8 C9 D6(1 4) DC(1 2 3 4 5 6 F0) DF F0(0 1 2 3 9) F2  E0(0 1 2 3))) -->
<monitor name="Samsung SyncMaster 226BW (Digital)">
        <controls>
                <control id="magicbright" type="list" address="0xdc">
                        <value id="text" value="1"/>
                        <value id="internet" value="2"/>
                        <value id="game" value="3"/>
                        <value id="sport" value="4"/>
                        <value id="entertain" value="5"/>
                        <value id="custom" value="6"/>
                        <value id="dynamic" value="240"/>
                </control>
        </controls>
	<include file="SAMlcd"/>
</monitor>

