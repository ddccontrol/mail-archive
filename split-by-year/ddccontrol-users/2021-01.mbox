<!--- "Standard" controls -->
<monitor name="GIGABYTE M27Q" init="standard">
	<controls>
		<!-- Can write, no clue what it does -->
		<control id="0x02" address="0x02">
			<value value="1" id="1"/>
			<value value="2" id="2"/>
		</control>

		<control id="defaults" address="0x04" delay="2000"/>

		<!-- Reset both color and luma -->
		<control id="defaultluma" address="0x05" delay="2000"/>
		<control id="defaultcolor" address="0x08" delay="2000"/>

		<!-- Control 0x0b: +/50/65535 C [???]
			Not sure what this does, can't change it ?-->

		<control id="colortemp" address="0x0c">
			<value value="40"  id="warm"/>
			<value value="70"  id="normal"/>
			<value value="126" id="cool"/>
		</control>

		<control id="brightness" address="0x10"/>
		<control id="contrast" address="0x12"/>

		<!-- Best to use colortemp, this is sort of broken -->
		<control id="colorpreset" address="0x14">
			<!-- Some weird mappings going on
				Internal values:
					Cool   > 4
					Normal > 5
					Warm   > 6
					User   > 7
					sRGB   > 8
					???    > 10
				Write -> Result:
					(After starting from 7)
					 0 >  7 ;  1 >  8 ;  2 >  7
					 3 >  7 ;  4 >  6 ;  5 >  5
					 6 > 10 ;  7 > 10 ;  8 >  4
					 9 >  7 ; 10 > 10 ; 11 >  7
			-->
			<value value="8"   id="(4) cool"/>
			<value value="5"   id="(5) normal"/>
			<value value="4"   id="(6) warm"/>
			<value value="11"  id="(7) user1"/>
			<value value="1"   id="(8) srgb"/>
			<value value="10"  id="(10) Unsupported"/>
		</control>

		<control id="red" address="0x16"/>
		<control id="green" address="0x18"/>
		<control id="blue" address="0x1A"/>
		
		<!-- Control 0x52: +/0/255 C [???]
			Not sure what this does, can't change it ?-->

		<control id="inputsource" address="0x60">
			<value value="17"   id="hdmi1"/>
			<value value="18"   id="hdmi2"/>
			<value value="15"   id="dp"/>
			<value value="16"   id="usb-c"/>
		</control>

		<control id="audiospeakervolume" address="0x62"/>

		<control id="redblack" address="0x6C"/>
		<control id="greenblack" address="0x6E"/>
		<control id="blueblack" address="0x70"/>

		<!-- 1=soft ; 5=off ; 10=sharp -->
		<control id="sharpness" address="0x87"/>

		<control id="audiospeakermute"   address="0x8d">
			<value value="1"   id="mute"/>
			<value value="2"   id="unmute"/>
		</control>

