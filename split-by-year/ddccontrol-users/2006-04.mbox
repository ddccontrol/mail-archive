+#endif
+	
 	mon->caps.raw_caps[bufferpos] = 0;
+
+	char* last_substr = mon->caps.raw_caps;
+	char* endptr;
+	while ((last_substr = strstr(last_substr, "bin("))) {
+		last_substr += 4;
+		printf("last_substr=%ld\n", last_substr-mon->caps.raw_caps);
