/*
 * i2c_client identifies a single device (i.e. chip) that is connected to a=
n=20
 * i2c bus. The behaviour is defined by the routines of the driver. This
 * function is mainly used for lookup & other admin. functions.
 */
struct i2c_client {
	int id;
