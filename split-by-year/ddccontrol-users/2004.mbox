	static struct i2c_client_address_data addr_data =3D {		\
			.normal_i2c =3D 		normal_i2c,		\
			.normal_i2c_range =3D	normal_i2c_range,	\
			.probe =3D		probe,			\
			.probe_range =3D		probe_range,		\
			.ignore =3D		ignore,			\
			.ignore_range =3D		ignore_range,		\
			.force =3D		force,			\
		}

/* Detect whether we are on the isa bus. If this returns true, all i2c
   access will fail! */
#define i2c_is_isa_client(clientptr) \
        ((clientptr)->adapter->algo->id =3D=3D I2C_ALGO_ISA)
#define i2c_is_isa_adapter(adapptr) \
        ((adapptr)->algo->id =3D=3D I2C_ALGO_ISA)

/* Tiny delay function used by the i2c bus drivers */
static inline void i2c_delay(signed long timeout)
{
	set_current_state(TASK_INTERRUPTIBLE);
	schedule_timeout(timeout);
}

#endif /* _LINUX_I2C_H */

