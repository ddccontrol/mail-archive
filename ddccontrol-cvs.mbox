<?xml version="1.0"?>
<!---Samsung 997MB is a CRT. CAPS invalid
(prot(monitor)type(crt)model(Andromeda(AN Series))edid bin(128(##########))
cmds(01 02 03 E3 F3)vcp(01 10 12 14 16 18 1A 20 22 24 26 30 32 3A 40 42 44 6C
